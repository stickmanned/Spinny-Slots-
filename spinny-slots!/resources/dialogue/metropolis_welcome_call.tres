[gd_resource type="Resource" script_class="DialogueData" format=3]

[ext_resource type="Script" path="res://scripts/dialogue_data.gd" id="1_dialogue"]

[resource]
script = ExtResource("1_dialogue")
lines = Array[String](["Welcome to Metropolis!", "This city is absolutely MASSIVE, so always watch where you're going!", "The slot machines here are also upgraded", "Some can give you random boosts, like multiply your total earnings per spin", "or some can literally \"Hack\" your spin if you have the special key!", "Just one tip before I go..", "Make sure to upgrade in the right upgrades panel so you can get the most out of the machines!", "happy gambling, and PEACE!"])
